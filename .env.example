# Copie este arquivo para .env e preencha com os dados do seu projeto Supabase.
# Painel Supabase → Project Settings → API

VITE_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sua_chave_anon_publicavel

# URL oficial em produção (Vercel) — usada em redirects e links
# VITE_APP_ORIGIN=https://seu-app.vercel.app

# E-mails com acesso total às páginas (opcional, separados por vírgula)
# VITE_PAGINAS_BYPASS_EMAILS=
